# Eve local configuration template.
#   1. Copy to .env  (cp .env.example .env)  — .env is gitignored, never committed
#   2. Fill in your real hostname, cert paths, and network ranges
#   3. Run:  npm run start:env   (loads .env via node --env-file)
#
# Keep real values ONLY in .env. This template uses placeholders on purpose.

# The single canonical HTTPS origin Eve is reached at (used on LAN, WireGuard,
# and the internet via split-horizon DNS). Pins WebAuthn + WebSocket origin.
EVE_PUBLIC_ORIGIN=https://eve.example.org

# Require the passkey on EVERY connection once enrolled (WireGuard, LAN, internet).
# Leave this set for the hardened door. Omit it if you instead want LAN/WireGuard
# to skip the passkey for convenience.
EVE_DISABLE_SUBNET_BYPASS=1

# With the bypass disabled (above), these subnets only allow the FIRST-passkey
# bootstrap: loopback + your LAN + your WireGuard subnet. After enrollment,
# everything still requires a passkey. Comma-separated CIDRs.
EVE_TRUSTED_SUBNETS=127.0.0.0/8,::1,192.168.0.0/24,10.0.0.0/24

# TLS — required for any networked deployment.
HTTPS_KEY=./certs/eve-key.pem
HTTPS_CERT=./certs/eve.pem

# Listen port for the hardened front door (align with your Firewalla 443 -> host
# forward; must not collide with the local loopback :3000 instance).
PORT=443

# --- eve-control MCP (lets an LLM open/close/refresh image tabs in eve) ---
# Shared secret for the loopback-only /internal/ui-command endpoint that the
# eve-control MCP calls. `npm run register:mcp` auto-generates this on first run
# and appends it here; the same value is handed to the MCP via `relay mcp
# register --env`. Leave unset to let registration generate one.
# EVE_INTERNAL_SECRET=
#
# Base URL the MCP POSTs to. Defaults to the loopback HTTP listener
# (http://127.0.0.1:${HTTP_PORT:-${PORT}}). Set explicitly only to override.
# EVE_INTERNAL_URL=http://127.0.0.1:3000
